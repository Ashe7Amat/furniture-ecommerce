# server/.env.example

# Puerto del servidor local (por defecto 5000)
PORT=5000

# URL del proyecto de Supabase (ej: https://xxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave de servicio de Supabase o Anon Key (Anon Key suele bastar para inserciones básicas si no hay RLS estrictas)
SUPABASE_ANON_KEY=tu-clave-de-supabase

# Configuración de notificaciones por Correo (SMTP / Nodemailer)
# Si se dejan en blanco, el sistema guardará logs simulados en la terminal en lugar de fallar.
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=tu-usuario-smtp@correo.com
SMTP_PASS=tu-contraseña-smtp

# Email donde el administrador recibirá las alertas de nuevas ventas
ADMIN_EMAIL=admin@nave5barcelona.com
